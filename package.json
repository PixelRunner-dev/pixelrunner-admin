{
  "name": "pixelrunner-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "config": {
    "project_name": "admin-vue",
    "remote_user": "root",
    "remote_pass": "pixelrunner",
    "remote_host": "192.168.5.178",
    "remote_dir": "/home/pixelrunner/pixelrunner26/admin-vue"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "preview:a11y": "vite preview -l error --port 4166 --strictPort",
    "audit": "npm audit --audit-level high",
    "outdated": "npm outdated",
    "a11y": "run-p -r -s preview:a11y a11y:axe",
    "a11y:axe": "axe -t best-practice http://localhost:4166",
    "benchmark": "vitest bench --ui",
    "test": "run-p test:unit test:e2e",
    "test:unit": "vitest run --coverage",
    "test:unit:ci": "vitest run --coverage --no-color --reporter dot",
    "test:unit:watch": "vitest watch --coverage --ui",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --quiet --reporter dot",
    "test:e2e:watch": "playwright test --ui",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-p lint:syntax lint:js",
    "lint:syntax": "prettier --check .",
    "lint:js": "eslint . --cache",
    "lint:js:ci": "eslint . --env-info",
    "format": "run-p format:syntax format:js",
    "format:syntax": "prettier --write --experimental-cli .",
    "format:js": "eslint . --fix",
    "ci": "DEBUG_COLORS=false run-p -s audit type-check lint:syntax lint:js:ci test:unit:ci test:e2e:ci",
    "update-geo": "node scripts/update-geo-db.mjs",
    "remote:npm-install": "npx remote-npm install",
    "remote:push": "npx remote-push"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "i18next": "^25.7.3",
    "i18next-vue": "^5.4.0",
    "pixelrunner-shared": "github:PixelRunner-dev/pixelrunner-shared",
    "trystero": "^0.22.0",
    "vue": "^3.5.26",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/eslint-plugin": "^1.6.4",
    "@vitest/ui": "^4.0.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.2",
    "eslint-plugin-playwright": "^2.4.0",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.7.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1"
  },
  "optionalDependencies": {
    "bufferutil": "*"
  }
}
